SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_JWT_SECRET="your-jwt-secret"
OMISE_PUBLIC_KEY="pkey_test_xxxxx"
OMISE_SECRET_KEY="skey_test_xxxxx"
# Active payment gateway: "omise" (default), "beam", or "manual".
# "manual" skips the gateway: it shows a PromptPay QR for MANUAL_PROMPTPAY_ID and
# an admin confirms each donation by hand (use while Omise/Beam are unverified).
PAYMENT_PROVIDER="omise"
# Your receiving PromptPay id (only needed when PAYMENT_PROVIDER=manual):
# a mobile number, national/tax id, or e-wallet id.
MANUAL_PROMPTPAY_ID="0812345678"
# Beam Checkout (only needed when PAYMENT_PROVIDER=beam). BEAM_API_URL defaults
# to production; use https://playground.api.beamcheckout.com for sandbox.
BEAM_API_URL="https://api.beamcheckout.com"
BEAM_MERCHANT_ID="your-beam-merchant-id"
BEAM_API_KEY="your-beam-api-key"
BEAM_WEBHOOK_SECRET="your-beam-webhook-hmac-secret-base64"
# Stripe (only needed when PAYMENT_PROVIDER=stripe). Phase 1 = PromptPay only.
STRIPE_SECRET_KEY="sk_test_xxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxx"
YOUTUBE_API_KEY="your-youtube-data-api-v3-key"
YOUTUBE_CHANNEL_ID="UC2HoBQZT88jlscMBsWzg8KA"
# Comma-separated allow-list of frontend origins for CORS.
FRONTEND_URL="http://localhost:3000"
# Set to "true" to also allow Vercel preview deploys (*.vercel.app).
ALLOW_VERCEL_PREVIEWS="false"
# PORT is injected by the host (Railway). Defaults to 3001 locally.
PORT=3001
